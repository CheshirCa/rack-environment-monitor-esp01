      "id": 100,
      "title": "Current Values",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue",  "value": null },
              { "color": "green", "value": 18 },
              { "color": "yellow","value": 28 },
              { "color": "red",   "value": 35 }
            ]
          },
          "unit": "celsius",
          "min": 0,
          "max": 50
