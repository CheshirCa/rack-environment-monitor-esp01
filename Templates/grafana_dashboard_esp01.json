        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "Temperature",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "esp01_temperature_celsius{sensor=~\"$sensor\"}",
          "legendFormat": "{{sensor}}",
          "refId": "A"
        }
      ]
    },
